def sm3_hash_upper(value: str) -> str:
    value_bytes = value.encode('utf-8')
    hash_list = sm3.sm3_hash(func.bytes_to_list(value_bytes))
    return hash_list.upper()

def match_attr(df):
    trans_mod = {'外卡':'0','内卡':'1'}
    df['卡来源']=df['卡来源'].map(trans_mod)
    df['卡等级']=df['卡等级'].map(lambda x : '0' + str(x))
    df['PAN输入方式'] = df['PAN输入方式'].map(lambda x : str(x)[:2] if pd.notna(x) else x)
    return df
    

def get_discount_transaction(
    trans_amt: str,          # 建议改为 Decimal 或 int
    pri_acct_num: str,
    sett_date: str           # YYYYMMDD 或 YYYY-MM-DD 均可，视表字段
) -> pd.DataFrame:
    # 差in-app
    pri_sm3 = sm3_hash_upper(pri_acct_num.strip())
    # 确定一致： PAN输入方式 --> SRV_ENTRY_MOD
    #           交易介质
    #           卡来源 --> 发卡属性
    # 卡等级、移动支付产品字段数据库更多
    # 卡产品 配置表信息更多, 定义有出入
    # 交易权限不管
    sql = f"""
    SELECT 交易时间,
           trans_amt 交易金额,
           pri_acct_num 发卡侧卡号,
           pri_acct_num_sm3 SM3加密卡号,
           acq_ins_cde 受理机构,
           收单地区 受理地区,
           mcc_cde 商户类型,
           mer_id 商户代码,
           卡BIN,
           发卡 发卡机构代码,
           card_rank_cde 卡等级,
           card_prdct_cde 卡产品,
           card_attr 卡性质,brand_cde 卡品牌,
           收单属性,发卡属性 卡来源,渠道 交易渠道, mpay_cde 移动支付产品, card_media 交易介质, srv_entry_mod PAN输入方式
           
           
    FROM szopr.tbl_daily_trans_temp_15
    WHERE trans_amt = '{trans_amt}'
      AND pri_acct_num_sm3 = '{pri_sm3}'
      AND sett_dt = TO_DATE('{sett_date}', 'YYYYMMDD')
    """
    df  = run_sql(sql)
    transform = match_attr(df)
    trans = clean_df(transform)
    t = json.dumps(
                trans.to_dict(orient="records"),
                indent=1,
                ensure_ascii=False
            )
    return t



def load_json(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        return json.load(f)
def remove_think(ans):
    pat = r'<think>.*?</think>'
    cleaned = re.sub(pat,'',ans,flags=re.DOTALL)
    cleaned = re.sub(r'\n\s*\n','\n\n',cleaned).strip()
    return cleaned

